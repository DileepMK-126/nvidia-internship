    "\n",
    "import os\n",
    "import glob\n",
    "import numpy as np\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras import layers, models\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# ==========================================\n",
    "# 1. GPU VERIFICATION\n",
    "# ==========================================\n",
    "print(\"--- Verifying GPU Hardware ---\")\n",
    "gpus = tf.config.list_physical_devices('GPU')\n",
    "print(\"Num GPUs Available: \", len(gpus))\n",
    "if len(gpus) > 0:\n",
    "    print(\"TensorFlow will train using your GPU.\")\n",
    "else:\n",
    "    print(\"WARNING: No GPU detected. Training will defaults to CPU.\")\n",
    "print(\"-\" * 30)\n",
    "\n",
    "# ==========================================\n",
    "# 2. DATA PATHS & HYPERPARAMETERS\n",
    "# ==========================================\n",
    "# Adjusted specifically to match your nested extraction path\n",
    "TRAIN_DIR = '/workspace/data/seg_train/seg_train'\n",
    "TEST_DIR = '/workspace/data/seg_test/seg_test'\n",
    "PRED_DIR = '/workspace/data/seg_pred/seg_pred'\n",
    "\n",
    "IMG_SIZE = (150, 150)\n",
    "BATCH_SIZE = 32\n",
    "EPOCHS = 20\n",
    "\n",
    "# ==========================================\n",
    "# 3. LOADING THE DATASETS\n",
    "# ==========================================\n",
    "print(\"Loading Training Dataset...\")\n",
    "train_dataset = tf.keras.utils.image_dataset_from_directory(\n",
    "    TRAIN_DIR,\n",
    "    image_size=IMG_SIZE,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    label_mode='categorical'\n",
    ")\n",
    "\n",
    "print(\"\\nLoading Testing/Validation Dataset...\")\n",
    "test_dataset = tf.keras.utils.image_dataset_from_directory(\n",
    "    TEST_DIR,\n",
    "    image_size=IMG_SIZE,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    label_mode='categorical'\n",
    ")\n",
    "\n",
    "class_names = train_dataset.class_names\n",
    "print(f\"\\nDetected Classes: {class_names}\")\n",
    "\n",
    "# Optimize performance for GPU training (Prefetching & Caching)\n",
    "AUTOTUNE = tf.data.AUTOTUNE\n",
    "train_dataset = train_dataset.cache().shuffle(1000).prefetch(buffer_size=AUTOTUNE)\n",
    "test_dataset = test_dataset.cache().prefetch(buffer_size=AUTOTUNE)\n",
    "\n",
    "# ==========================================\n",
    "# 4. BUILDING THE CNN MODEL\n",
    "# ==========================================\n",
    "model = models.Sequential([\n",
    "    # Input Rescaling (Normalizes pixel values from 0-255 to 0-1)\n",
    "    layers.Rescaling(1./255, input_shape=(150, 150, 3)),\n",
    "    \n",
    "    # Conv Block 1\n",
    "    layers.Conv2D(32, (3, 3), activation='relu'),\n",
    "    layers.MaxPooling2D((2, 2)),\n",
    "    \n",
    "    # Conv Block 2\n",
    "    layers.Conv2D(64, (3, 3), activation='relu'),\n",
    "    layers.MaxPooling2D((2, 2)),\n",
    "    \n",
    "    # Conv Block 3\n",
    "    layers.Conv2D(128, (3, 3), activation='relu'),\n",
    "    layers.MaxPooling2D((2, 2)),\n",
    "    \n",
    "    # Conv Block 4\n",
    "    layers.Conv2D(128, (3, 3), activation='relu'),\n",
    "    layers.MaxPooling2D((2, 2)),\n",
    "    \n",
    "    # Flattening and Dense Layers\n",
    "    layers.Flatten(),\n",
    "    layers.Dense(512, activation='relu'),\n",
    "    layers.Dropout(0.5), # Helps prevent overfitting\n",
    "    layers.Dense(len(class_names), activation='softmax')\n",
    "])\n",
    "\n",
    "model.compile(\n",
    "    optimizer='adam',\n",
    "    loss='categorical_crossentropy',\n",
    "    metrics=['accuracy']\n",
    ")\n",
    "\n",
    "print(\"\\n--- Model Architecture Summary ---\")\n",
    "model.summary()\n",
    "print(\"-\" * 30)\n",
    "\n",
    "# ==========================================\n",
    "# 5. TRAINING THE MODEL\n",
    "# ==========================================\n",
    "print(f\"\\nStarting training for {EPOCHS} epochs on GPU...\")\n",
    "history = model.fit(\n",
    "    train_dataset,\n",
    "    validation_data=test_dataset,\n",
    "    epochs=EPOCHS\n",
    ")\n",
    "print(\"\\nTraining Finished!\")\n",
    "\n",
    "# ==========================================\n",
    "# 6. ANALYZING PERFORMANCE\n",
    "# ==========================================\n",
    "acc = history.history['accuracy']\n",
    "val_acc = history.history['val_accuracy']\n",
    "loss = history.history['loss']\n",
    "val_loss = history.history['val_loss']\n",
    "epochs_range = range(EPOCHS)\n",
    "\n",
    "# Plot Training & Validation Metrics\n",
    "plt.figure(figsize=(14, 5))\n",
    "\n",
    "# Plot Accuracy Curve\n",
    "plt.subplot(1, 2, 1)\n",
    "plt.plot(epochs_range, acc, label='Training Accuracy', color='blue', lw=2)\n",
    "plt.plot(epochs_range, val_acc, label='Validation Accuracy', color='orange', lw=2)\n",
    "plt.title('Training and Validation Accuracy')\n",
    "plt.xlabel('Epochs')\n",
    "plt.ylabel('Accuracy')\n",
    "plt.legend(loc='lower right')\n",
    "plt.grid(True, linestyle='--', alpha=0.6)\n",
    "\n",
    "# Plot Loss Curve\n",
    "plt.subplot(1, 2, 2)\n",
    "plt.plot(epochs_range, loss, label='Training Loss', color='blue', lw=2)\n",
    "plt.plot(epochs_range, val_loss, label='Validation Loss', color='orange', lw=2)\n",
    "plt.title('Training and Validation Loss')\n",
    "plt.xlabel('Epochs')\n",
    "plt.ylabel('Loss')\n",
    "plt.legend(loc='upper right')\n",
    "plt.grid(True, linestyle='--', alpha=0.6)\n",
    "\n",
    "plt.show()\n",
    "\n",
    "# ==========================================\n",
    "# 7. OPTIONAL: PREDICTION ON UNLABELLED DATA\n",
    "# ==========================================\n",
    "print(\"\\n--- Testing Single Inference from seg_pred ---\")\n",
    "# Finding the first image file available in the unlabelled pred folder\n",
    "pred_images = glob.glob(os.path.join(PRED_DIR, '*.*'))\n",
    "\n",
    "if pred_images:\n",
    "    sample_img_path = pred_images[0]\n",
    "    print(f\"Predicting for sample image: {sample_img_path}\")\n",
    "    \n",
    "    # Load and prep image\n",
    "    img = tf.keras.utils.load_img(sample_img_path, target_size=IMG_SIZE)\n",
    "    img_array = tf.keras.utils.img_to_array(img)\n",
    "    img_array = tf.expand_dims(img_array, 0) # Create a batch of 1\n",
    "    \n",
    "    # Run prediction\n",
    "    predictions = model.predict(img_array)\n",
    "    score = tf.nn.softmax(predictions[0])\n",
    "    \n",
    "    print(f\"\\nResult: This image most likely belongs to '{class_names[np.argmax(score)]}' \"\n",
    "          f\"with a {100 * np.max(score):.2f}% confidence score.\")\n",
    "else:\n",
    "    print(\"No images found in your prediction folder to showcase inference.\")\n",
    "\n"
   ]
  }
