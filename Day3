    "     [1,1]]\n",
    "\n",
    "y = [0,1,1,0]\n",
    "\n",
    "# Neural Network\n",
    "model = MLPClassifier(hidden_layer_sizes=(4,),\n",
    "                      max_iter=5000,\n",
    "                      random_state=42)\n",
    "\n",
    "model.fit(X, y)\n",
    "\n",
    "print(\"Predictions:\")\n",
    "print(model.predict(X))\n"
   ]
